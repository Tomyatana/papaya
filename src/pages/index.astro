---
import Header from "../components/Header.astro";
import List from "../components/List.astro"

import Layout from '../layouts/Layout.astro';

import type { ModrinthFacets } from '../components/modrinth-api.ts'
import Footer from "../components/Footer.astro";

let mod_facet: ModrinthFacets = {
    project_type: null,
    version: null,
    categories: null
}

let resource_pack_facet: ModrinthFacets = {
    project_type: "resourcepack",
    version: null,
    categories: null
}

let shader_facet: ModrinthFacets = {
    project_type: "shader",
    version: null,
    categories: null
}

let pack_facet: ModrinthFacets = {
    project_type: "modpack",
    version: null,
    categories: null
}
---

<Layout>
	<Header />
	<List facet={mod_facet} title="Mods" />
	<List facet={resource_pack_facet} title="Resource Packs" />
    <List facet={shader_facet} title="Shaders" />
    <List facet={pack_facet} title="Mod Packs" />
    <Footer />
</Layout>
