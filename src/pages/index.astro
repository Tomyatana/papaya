---
import Header from "../components/Header.astro";
import List from "../components/List.astro"

import Layout from '../layouts/Layout.astro';

import { search_projects } from '../components/modrinth-api.ts'
import type { ModrinthFacets } from '../components/modrinth-api.ts'

let mod_facet: ModrinthFacets = {
    project_type: "mod",
    version: null,
    categories: null
}

let mods = await search_projects("", mod_facet)

let resource_pack_facet: ModrinthFacets = {
    project_type: "resourcepack",
    version: null,
    categories: null
}

let resource_packs = await search_projects("", resource_pack_facet)

let shader_facet: ModrinthFacets = {
    project_type: "shader",
    version: null,
    categories: null
}

let shaders = await search_projects("", shader_facet)
---

<Layout>
	<Header />
	<List mods={mods} title="Mods" />
	<List mods={resource_packs} title="Resource Packs" />
    <List mods={shaders} title="Shaders" />
</Layout>
