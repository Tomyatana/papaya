---
import ModEntry from './ModEntry.astro'
import { search_projects, type ModrinthFacets, type ModrinthMod } from './modrinth-api.ts'

const { facet, title } = Astro.props as { facet: ModrinthFacets, title: String }

let mods = await search_projects("", facet);

---
<h2> {title} </h2>
<div class="wrapper">
	<div class="modlist">
		{ mods.map((m)=> <ModEntry mod={m} /> ) }
		{ mods.map((m)=> <ModEntry mod={m} /> ) }
	</div>
</div>

<style>
</style>
