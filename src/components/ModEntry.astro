---
import type { ModrinthMod } from './modrinth-api.ts'
import '../styles/ModEntry.css'

const { mod } = Astro.props as { mod: ModrinthMod }

function mod_to_string(hit: ModrinthMod) {
    let string = `${hit.title} (${hit.author})`
    if (hit.desc != null) {
        string + `: ${hit.desc}`
    }

    return string
}

function mod_image(hit: ModrinthMod): string {
    let string = (hit.icon) ? hit.icon.toString() : "/favicon.ico"
    return string
}

function mod_link(hit: ModrinthMod): string {
	return `https://modrinth.com/${hit.type}/${hit.slug}`
}

---

<div class="container">
    <img src={mod_image(mod)}>
	<a href={mod_link(mod)} target="_blank"> {mod_to_string(mod)} </a>
</div>

<style>
.container {
	display: inline-flex;
	align-items: center;
	gap: 1rem;

    border: 1px solid #bcbcbca0;
	border-radius: 10px;
	padding: 3px;
	padding-right: 1rem;

	background-color: black;

	margin-bottom: 5px;
	margin-right: 10px;
	margin-left: 5px;
	position: relative;
}

a {
	color: green;
}

img {
    display: inline-block;
    float: left;
    width: 50px;
    height: 50px;
    object-fit: cover;
	border: 1px solid #bcbcbc40;
	border-radius: 10px;
}
</style>
