---
import type { ModrinthMod } from './modrinth-api.ts'
import '../styles/ModEntry.css'

const { mod } = Astro.props

export function mod_to_string(hit: ModrinthMod) {
    let string = `${hit.title} (${hit.author})`
    if (hit.desc != null) {
        string + `: ${hit.desc}`
    }

    return string
}

export function mod_image(hit: ModrinthMod): string {
    let string = (hit.icon) ? hit.icon.toString() : "/favicon.ico"
    console.log(string)
    return string
}

---

<div class="container">
    <img src={mod_image(mod)}>
    <p> {mod_to_string(mod)} </p>
</div>

<style>
.container {
	display: inline-grid;
	grid-template-columns: auto 1fr;
	align-items: center;
	gap: 10px;

    border: 5px solid black;
	border-radius: 15px;
	padding: 3px;
	background-color: black;

	margin-right: 10px;
	margin-left: 5px;
}

p {
	color: green;
}

img {
    display: inline-block;
    float: left;
    padding-right: 10px;
    width: 50px;
    height: 50px;
    object-fit: cover;
}
</style>
