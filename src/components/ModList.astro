---
import ModEntry from './ModEntry.astro'
import type { ModrinthMod } from './modrinth-api.ts'

const { mods } = Astro.props as { mods: ModrinthMod[] }

---

<div id="modlist">
    { mods.map((m: any)=> <ModEntry mod={m} class="entry"/> ) }
</div>

<style>

.entry {
	padding-right: 16px;
}

</style>
